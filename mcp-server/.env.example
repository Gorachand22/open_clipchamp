# Clipchamp MCP Server Environment Variables

# Clipchamp Web App URL (default: http://localhost:3000)
CLIPCHAMP_URL=http://localhost:3000

# Projects Directory
CLIPCHAMP_PROJECTS_DIR=/home/babul/open_clipchamp/projects

# Z.ai API Key for AI generation (optional)
# Z_AI_API_KEY=your-api-key-here

# Z Audio API (for TTS)
# Z_AUDIO_TOKEN=your-token
# Z_AUDIO_USER_ID=your-user-id
