{
  "manifest_version": 3,
  "name": "Qwen Automation - AI Generation",
  "version": "1.1.0",
  "version_name": "1.1.0",
  "description": "Automate Qwen AI for image/video generation. Works with existing chat session - no refresh needed. Supports text-to-image, text-to-video, image-to-video.",
  "author": {
    "email": "qwen-automation@example.com"
  },
  "permissions": [
    "storage",
    "tabs",
    "background",
    "sidePanel",
    "activeTab",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "*://chat.qwen.ai/*",
    "*://*.qwen.ai/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_title": "Qwen Automation",
    "default_icon": {
      "16": "src/assets/logo.png",
      "32": "src/assets/logo.png",
      "48": "src/assets/logo.png",
      "128": "src/assets/logo.png"
    }
  },
  "icons": {
    "16": "src/assets/logo.png",
    "32": "src/assets/logo.png",
    "48": "src/assets/logo.png",
    "128": "src/assets/logo.png"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://chat.qwen.ai/*"],
      "js": ["assets/content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "src/ui/side-panel/index.html"
  },
  "offline_enabled": true,
  "web_accessible_resources": [
    {
      "resources": ["assets/content.js", "src/assets/logo.png"],
      "matches": ["*://chat.qwen.ai/*"],
      "use_dynamic_url": false
    }
  ]
}
